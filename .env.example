# Database
DB_USER=prolog
DB_PASSWORD=changeme_use_a_strong_password
DB_NAME=prolog

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=
JWT_EXPIRY_DAYS=7

# Anthropic Claude API key (server-side only — never sent to browser)
CLAUDE_API_KEY=

# CORS — frontend origin(s), comma-separated
FRONTEND_ORIGIN=https://prolog.bltbox.com

# Environment
NODE_ENV=production
